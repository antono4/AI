# ============== API KEYS ==============

# OpenAI (GPT untuk content generation, TTS)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude untuk advanced content)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ElevenLabs (Premium AI Voice)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Replicate (AI Video Generation - Runway, Pika, etc.)
REPLICATE_API_TOKEN=your-replicate-api-token-here

# Pexels (Stock Video)
PEXELS_API_KEY=your-pexels-api-key-here

# Pixabay (Stock Video)
PIXABAY_API_KEY=your-pixabay-api-key-here

# ============== YOUTUBE ==============
# Place your client_secret.json in the project root
YOUTUBE_CLIENT_SECRET=client_secret.json
YOUTUBE_TOKEN_PICKLE=youtube_token.pickle

# Google OAuth Credentials (for auto upload)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
REDIRECT_URI=http://localhost:5000/oauth/callback

# Target YouTube Channel
YOUTUBE_CHANNEL_ID=UCantonockr7618
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@antonockr7618
YOUTUBE_CHANNEL_NAME=antonockr7618

# ============== OUTPUT PATHS ==============
OUTPUT_DIR=output
VIDEOS_DIR=videos
TEMP_DIR=temp
LOGS_DIR=logs

# ============== SCHEDULER ==============
ENABLE_AUTO_SCHEDULE=true
DEFAULT_SCHEDULE_TIME=09:00

# ============== LIMITS ==============
MAX_DAILY_VIDEOS=10
MAX_CONCURRENT_UPLOADS=2